{
  "name": "identity-firewall-extension",
  "version": "0.1.0",
  "description": "Browser extension for identity firewall",
  "scripts": {
    "build": "esbuild src/background.ts src/content.ts ui/popup.ts --bundle --outdir=dist --external:chrome",
    "dev": "npm run build -- --sourcemap --watch",
    "type-check": "tsc --noEmit",
    "typecheck": "npm run type-check",
    "lint": "npm run type-check",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/chrome": "^0.0.246",
    "@types/node": "^24.3.0",
    "esbuild": "^0.27.3",
    "tsx": "^4.20.5",
    "typescript": "^5.3.0"
  }
}
